# Shopify Admin API
# Crie um Private App em: Admin → Apps → Develop apps
SHOPIFY_SHOP_DOMAIN=minha-loja.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# PostgreSQL (docker-compose local)
DATABASE_URL=postgresql://sales_agent:sales_agent_pass@localhost:5432/sales_agent

# Configurações do agente (opcionais)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
AGENT_VERBOSE=true
